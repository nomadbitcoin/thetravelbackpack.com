---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us - The Travel Backpack"
  description="Get in touch with The Travel Backpack team. We'd love to hear from you about gear questions, collaborations, or feedback."
  canonical="https://thetravelbackpack.com/contact-us/"
>
  <div class="py-12">
    <div class="container-custom max-w-3xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-xl text-gray-600 mb-12">
        Have a question or want to work together? We'd love to hear from you.
      </p>

      <div class="bg-white rounded-lg shadow-md p-8">
        <form
          name="contact"
          method="POST"
          action="/contact-us/?success=true"
          class="space-y-6"
        >
          <div>
            <label for="name" class="block text-sm font-semibold text-gray-700 mb-1">
              Your Name
            </label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-semibold text-gray-700 mb-1">
              Email Address
            </label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
          </div>

          <div>
            <label for="subject" class="block text-sm font-semibold text-gray-700 mb-1">
              Subject
            </label>
            <input
              type="text"
              id="subject"
              name="subject"
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-semibold text-gray-700 mb-1">
              Message
            </label>
            <textarea
              id="message"
              name="message"
              rows={6}
              required
              class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-primary-500"
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn btn-primary w-full"
          >
            Send Message
          </button>
        </form>
      </div>

      <div class="mt-8 text-gray-600 text-sm">
        <p>We typically respond within 1-2 business days.</p>
      </div>
    </div>
  </div>
</BaseLayout>
