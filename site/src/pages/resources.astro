---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Travel Resources - Guides & Tools | The Travel Backpack"
  description="Curated travel resources including packing guides, gear checklists, and buying guides to help you travel smarter."
  canonical="https://thetravelbackpack.com/resources/"
>
  <div class="py-12">
    <div class="container-custom max-w-4xl">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Travel Resources</h1>
      <p class="text-xl text-gray-600 mb-12">
        Everything you need to plan, pack, and travel smarter — curated guides, checklists, and gear recommendations.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Buying Guides -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="bg-primary-100 w-12 h-12 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl">🎒</span>
          </div>
          <h2 class="text-2xl font-bold mb-3">Buying Guides</h2>
          <p class="text-gray-600 mb-4">
            In-depth guides to help you choose the right backpack for your needs and budget.
          </p>
          <a href="/blog/" class="text-primary-600 font-semibold hover:text-primary-700">
            Browse Buying Guides →
          </a>
        </div>

        <!-- Packing Guides -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="bg-primary-100 w-12 h-12 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl">📋</span>
          </div>
          <h2 class="text-2xl font-bold mb-3">Packing Guides</h2>
          <p class="text-gray-600 mb-4">
            Step-by-step packing lists and guides for every type of trip.
          </p>
          <a href="/blog/" class="text-primary-600 font-semibold hover:text-primary-700">
            Browse Packing Guides →
          </a>
        </div>

        <!-- Travel Backpacks -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="bg-primary-100 w-12 h-12 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl">✈️</span>
          </div>
          <h2 class="text-2xl font-bold mb-3">Travel Backpacks</h2>
          <p class="text-gray-600 mb-4">
            Top picks for carry-on travel, digital nomads, and long-haul adventures.
          </p>
          <a href="/travel-backpacks/" class="text-primary-600 font-semibold hover:text-primary-700">
            Browse Travel Backpacks →
          </a>
        </div>

        <!-- Hiking Backpacks -->
        <div class="bg-white rounded-lg shadow-md p-6">
          <div class="bg-primary-100 w-12 h-12 rounded-full flex items-center justify-center mb-4">
            <span class="text-2xl">🏔️</span>
          </div>
          <h2 class="text-2xl font-bold mb-3">Hiking Backpacks</h2>
          <p class="text-gray-600 mb-4">
            Trail-tested picks for day hikes, backpacking trips, and everything in between.
          </p>
          <a href="/hiking-backpacks/" class="text-primary-600 font-semibold hover:text-primary-700">
            Browse Hiking Backpacks →
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
