---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../../components/BreadcrumbSchema.astro';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const categoryPosts = posts
  .filter((p) => p.data.originalUrl && p.data.originalUrl.includes('/travel-backpacks/'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Travel Backpacks - Reviews & Guides | The Travel Backpack"
  description="Find the best travel backpacks with expert reviews, comparisons, and buying guides for every type of traveler."
  canonical="https://thetravelbackpack.com/travel-backpacks/"
>
  <BreadcrumbSchema
    items={[
      { name: 'Home', url: '/' },
      { name: 'Travel Backpacks', url: '/travel-backpacks/' },
    ]}
    slot="head"
  />

  <div class="py-12">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Travel Backpacks</h1>
      <p class="text-xl text-gray-600 mb-12">
        Expert reviews and guides for the best travel backpacks — from weekend getaways to year-long adventures.
      </p>

      {categoryPosts.length === 0 ? (
        <p class="text-gray-500">No posts found yet. Check back soon!</p>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {categoryPosts.map((post) => (
            <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
              <div class="bg-gray-200 h-48 flex items-center justify-center">
                <span class="text-gray-400">Image</span>
              </div>
              <div class="p-6">
                <div class="text-sm text-gray-500 mb-2">
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </div>
                <h2 class="text-xl font-bold mb-3">
                  <a href={`/travel-backpacks/${post.slug}`} class="hover:text-primary-600">
                    {post.data.title}
                  </a>
                </h2>
                <p class="text-gray-600 mb-4">{post.data.description}</p>
                <a href={`/travel-backpacks/${post.slug}`} class="text-primary-600 font-semibold hover:text-primary-700">
                  Read More →
                </a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>
