---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');

  // Filter for budget-backpacks category
  const budgetPosts = posts.filter((post) =>
    post.data.originalUrl && post.data.originalUrl.includes('/budget-backpacks/')
  );

  return budgetPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.date.toISOString()}
  modifiedTime={post.data.updated?.toISOString()}
  tags={post.data.tags}
  image={post.data.featured_image}
>
  <article class="py-12">
    <div class="container-custom max-w-4xl">
      <!-- Article Header -->
      <header class="mb-8">
        <div class="text-sm text-gray-500 mb-2">
          {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">{post.data.title}</h1>
        <p class="text-xl text-gray-600">{post.data.description}</p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.map((tag) => (
            <span class="bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-sm">
              {tag}
            </span>
          ))}
        </div>

        <!-- SEO Keyword Badge (if present) -->
        {post.data.targetKeyword && (
          <div class="mt-4 text-sm text-gray-500">
            <span class="font-semibold">Target Keyword:</span> {post.data.targetKeyword}
          </div>
        )}
      </header>

      <!-- Featured Image Placeholder -->
      {post.data.featured_image && (
        <div class="bg-gray-200 rounded-lg h-96 flex items-center justify-center mb-8">
          <span class="text-gray-400">Featured Image: {post.data.featured_image.alt}</span>
        </div>
      )}

      <!-- Article Content -->
      <div class="prose prose-lg max-w-none">
        <Content />
      </div>

      <!-- Affiliate Disclosure -->
      {post.data.affiliate_disclosure && (
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4 mt-8">
          <p class="text-sm text-gray-700">
            <strong>Disclosure:</strong> This post contains affiliate links. If you purchase through these links,
            we may earn a commission at no extra cost to you. We only recommend products we've personally researched or used.
          </p>
        </div>
      )}

      <!-- Recovery Notice (Optional - can be removed later) -->
      {post.data.recoveredFrom && (
        <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mt-4">
          <p class="text-sm text-gray-600">
            ℹ️ This content was recovered from the Wayback Machine and preserved for SEO continuity.
            Original URL: <a href={post.data.originalUrl} class="text-primary-600 hover:underline" target="_blank" rel="nofollow">{post.data.originalUrl}</a>
          </p>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
