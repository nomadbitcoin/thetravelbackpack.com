---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  const sorted = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

  const pageSize = 5;
  const totalPages = Math.ceil(sorted.length / pageSize);

  return Array.from({ length: totalPages - 1 }, (_, i) => {
    const page = i + 2; // pages 2, 3, 4, ...
    const start = (page - 1) * pageSize;
    const pagePosts = sorted.slice(start, start + pageSize);
    return {
      params: { page: String(page) },
      props: { pagePosts, page, totalPages },
    };
  });
}

const { pagePosts, page, totalPages } = Astro.props;
---

<BaseLayout
  title={`Travel Blog - Page ${page} | The Travel Backpack`}
  description={`Browse travel guides, gear reviews, and backpack recommendations - page ${page}.`}
>
  <div class="py-12">
    <div class="container-custom">
      <h1 class="text-4xl md:text-5xl font-bold mb-8">Travel Blog</h1>
      <p class="text-gray-500 mb-8">Page {page} of {totalPages}</p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {pagePosts.map((post) => (
          <article class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition-shadow">
            <div class="bg-gray-200 h-48 flex items-center justify-center">
              <span class="text-gray-400">Image</span>
            </div>
            <div class="p-6">
              <div class="text-sm text-gray-500 mb-2">
                {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
              </div>
              <h2 class="text-xl font-bold mb-3">
                <a href={`/blog/${post.slug}`} class="hover:text-primary-600">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-gray-600 mb-4">{post.data.description}</p>
              <a href={`/blog/${post.slug}`} class="text-primary-600 font-semibold hover:text-primary-700">
                Read More →
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination nav -->
      <nav class="flex justify-between mt-12">
        <a
          href={page - 1 === 1 ? '/blog/' : `/page/${page - 1}/`}
          class="btn btn-primary"
        >
          ← Previous
        </a>
        {page < totalPages && (
          <a href={`/page/${page + 1}/`} class="btn btn-primary">
            Next →
          </a>
        )}
      </nav>
    </div>
  </div>
</BaseLayout>
